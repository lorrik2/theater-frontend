{
  "kind": "collectionType",
  "collectionName": "performances",
  "info": {
    "singularName": "performance",
    "pluralName": "performances",
    "displayName": "Спектакли",
    "description": "Спектакли театра"
  },
  "options": { "draftAndPublish": false },
  "pluginOptions": {},
  "attributes": {
    "title": { "type": "string", "required": true },
    "slug": { "type": "uid", "targetField": "title", "required": true },
    "poster": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "heroSlider": {
      "type": "media",
      "multiple": true,
      "required": false,
      "allowedTypes": ["images"],
      "description": "Фото для слайдера наверху страницы спектакля. Если пусто — используются фото из галереи."
    },
    "gallery": {
      "type": "media",
      "multiple": true,
      "required": false,
      "allowedTypes": ["images"],
      "description": "Фотогалерея (ниже на странице). Отдельно от слайдера."
    },
    "subtitle": { "type": "string" },
    "author": { "type": "string" },
    "director": { "type": "string" },
    "directorQuote": { "type": "text" },
    "designer": { "type": "string" },
    "lightingDesigner": { "type": "string" },
    "soundDesigner": { "type": "string" },
    "lightSoundOperator": { "type": "string" },
    "invitedCast": {
      "type": "component",
      "repeatable": true,
      "component": "shared.cast-member",
      "description": "Внешний состав — приглашённые артисты, музыканты и др. Только люди не из команды. Актёров из команды добавляйте в карточке актёра (Роли в спектаклях)."
    },
    "reviews": {
      "type": "component",
      "repeatable": true,
      "component": "shared.review"
    },
    "teaserUrl": { "type": "string" },
    "date": { "type": "string" },
    "time": { "type": "string" },
    "ageRating": { "type": "string" },
    "genre": { "type": "string" },
    "description": { "type": "text" },
    "duration": { "type": "string" },
    "intermissions": { "type": "integer" },
    "isPremiere": { "type": "boolean", "default": false },
    "inAfisha": { "type": "boolean", "default": true },
    "schedule": {
      "type": "component",
      "repeatable": true,
      "component": "shared.schedule-item"
    },
    "awards": {
      "type": "component",
      "repeatable": true,
      "component": "shared.award"
    },
    "festivals": {
      "type": "component",
      "repeatable": true,
      "component": "shared.festival"
    },
    "ticketsUrl": {
      "type": "string",
      "description": "Ссылка на покупку билетов. Если пусто — кнопка «Купить билет» на слайдере не показывается."
    },
    "ticketButtonLabel": {
      "type": "string",
      "description": "Текст кнопки на слайдере (например «Купить билет»). Если пусто — используется «Купить билет»."
    },
    "featuredBlockImage": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"],
      "description": "Чёрный блок перед отзывами: одна главная фотография"
    },
    "featuredBlockText": {
      "type": "text",
      "required": false,
      "description": "Чёрный блок: текст (описание, цитата)"
    },
    "featuredBlockGallery": {
      "type": "media",
      "multiple": true,
      "required": false,
      "allowedTypes": ["images"],
      "description": "Чёрный блок: карусель фото (альбомные)"
    }
  }
}
