# Next.js (см. .env для своих значений)
# NEXT_PUBLIC_SITE_URL=https://teatrkrug.ru  # Каноникал: https, non-www, без / (редиректы www→non-www, http→https)
# NEXT_PUBLIC_YANDEX_MAP_APIKEY=...
# NEXT_PUBLIC_YANDEX_METRIKA_ID=   # Счётчик Яндекс.Метрики (только цифры, напр. 12345678)

# Strapi CMS — опционально, для подключения к headless CMS
# По умолчанию используется http://localhost:1337
# STRAPI_URL=http://localhost:1337
# NEXT_PUBLIC_STRAPI_URL=http://localhost:1337

# USE_STRAPI=1 — принудительно брать данные из Strapi (для локальной разработки)

# API токен Strapi — для защищённых API (если включено)
# STRAPI_API_TOKEN= — опционально, для защищённого API
